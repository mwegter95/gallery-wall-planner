# ── Gallery Wall Planner — environment variables ──────────────────────────────
#
# Copy this file to .env.local for local development.
# Set these in your Netlify dashboard for production.

# URL of the mw-backend server.
# - Dev:  leave blank (Vite proxy handles it: /api/* → localhost:5050)
# - Prod: set to your Cloudflare Tunnel URL, e.g.:
VITE_API_URL=https://api.michaelwegter.com
